val test_reach_1 = let
    val vertex = [1,2,3,4,5,6,7,8,9]
    val edges = [(1,2),(1,4),(2,3),(2,5),(3,6),(3,5),(4,1),(4,5),(5,7),(5,8),(6,9),(7,4),(7,8),(8,9),(9,6)]
    val reach = reachability vertex edges [1]
in
    sort (op<) reach
end;

