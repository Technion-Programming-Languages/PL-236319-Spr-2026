fun insert cmp x [] = [x]
  | insert cmp x (y::ys) =
      if cmp (x, y) then
        x :: y :: ys
      else
        y :: insert cmp x ys

fun sort cmp [] = []
  | sort cmp (x::xs) = insert cmp x (sort cmp xs);

