        NEXT(song7,fn()=>
        NEXT(song8,fn()=>
        NIL))))

    val allPlaylist =
        combinePlaylists
            (combinePlaylists playlist1 playlist2)
            playlist3

    val res = filter (SOME("Rick Astley")) NONE allPlaylist
in
    toList res
end;

val test2_3 = let
    val playlist1 =
        NEXT(song5,fn()=>
        NEXT(song2,fn()=>
        NIL))

    val playlist2 =
        NEXT(song3,fn()=>
        NEXT(song4,fn()=>
