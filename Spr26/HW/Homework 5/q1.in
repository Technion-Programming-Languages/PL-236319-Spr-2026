(* sortPlaylist *)

val test3 = let
    val playlist1 =
        NEXT(song5,fn()=>
        NEXT(song2,fn()=>
        NIL))

    val playlist2 =
        NEXT(song3,fn()=>
        NEXT(song4,fn()=>
        NIL))

    val playlist3 =
        NEXT(song1,fn()=>
        NEXT(song6,fn()=>
        NEXT(song7,fn()=>
        NEXT(song8,fn()=>
        NIL))))

    val allPlaylist =
        combinePlaylists
            (combinePlaylists playlist1 playlist2)
            playlist3

    val res = sortPlaylist allPlaylist
in
    toList res
end;

print "===TEST ADVANCED_PLAYLIST ===\n";

val allPlaylist = let
    val playlist1 =
        NEXT(song5, fn () =>
        NEXT(song2, fn () =>
        NIL))

    val playlist2 =
        NEXT(song3, fn () =>
        NEXT(song4, fn () =>
        NIL))

    val playlist3 =
        NEXT(song1, fn () =>
        NEXT(song6, fn () =>
        NEXT(song7, fn () =>
        NEXT(song8, fn () =>
        NIL))))
in
    combinePlaylists
        (combinePlaylists playlist1 playlist2)
        playlist3
end;

val helperPrint = toList allPlaylist;

val (skip, play) = advancedPlaylist allPlaylist

